# Variáveis embutidas no build do totem físico (corte.bat opções 2 e 3).
# API local no PC de desenvolvimento — nunca use URL do Railway aqui.
VITE_API_URL=http://127.0.0.1:3333
VITE_PRINT_API_URL=http://127.0.0.1:3333
VITE_PUBLIC_URL=http://127.0.0.1:4173

# Opcional (corte.bat opção 2): abre a URL publicada em vez de localhost:4173
# Atenção: sem o print-server local (corte.bat), a impressão pode falhar.
# VITE_TOTEM_UI_URL=https://seu-app.vercel.app/
VITE_PRINT_SERVER_URL=http://127.0.0.1:3334
