# URL do backend principal (Railway em produção, localhost em desenvolvimento)
VITE_API_URL=http://localhost:3333

# URL do backend local para impressão (sempre localhost — impressora está no totem, não na nuvem)
# Se omitido, o app usa VITE_API_URL como fallback para POST /totem/:slug/print
VITE_PRINT_API_URL=http://localhost:3333

# URL pública do frontend (HTTPS em produção) — usada para montar links de logo das lojas
# Ex.: https://app.cortes.com.br  →  https://app.cortes.com.br/assets/tenants/corte/logo.png
VITE_PUBLIC_URL=http://localhost:5173
