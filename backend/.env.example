# =============================================================================
# CORTES APP — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env no git
# =============================================================================

# Ambiente
NODE_ENV=development

# Servidor
PORT=3333

# Banco de dados PostgreSQL
# Railway fornece essa variável automaticamente ao adicionar o plugin PostgreSQL
DATABASE_URL="postgresql://usuario:senha@host:5432/cortes_app"

# JWT — gere uma chave forte: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="sua-chave-secreta-com-no-minimo-32-caracteres"
JWT_EXPIRES_IN="8h"

# Segurança de senhas
BCRYPT_ROUNDS=12

# CORS — origens permitidas (separadas por vírgula)
# Em produção: coloque apenas o domínio do Vercel
CORS_ORIGINS="http://localhost:5173,http://localhost:4173,http://127.0.0.1:4173,https://seu-app.vercel.app"

# Impressora física do totem (nome exato listado no Windows — deixe vazio para usar a padrão)
# Para listar as impressoras disponíveis: Get-Printer | Select-Object Name (PowerShell)
# PRINTER_NAME=POS-58

# Integração Veltrix (opcional — configure também store_integrations no banco)
# apiBaseUrl = URL do Spring Boot (Railway), NÃO https://veltrix-gray.vercel.app
# apiKey = senha da conta de serviço | integrationMeta = {"email":"sync@empresa.com"}
# VELTRIX_API_URL=https://seu-backend-veltrix.up.railway.app

# Admin inicial (bootstrap no deploy — ver prisma/bootstrap-admin.cjs)
# ADMIN_BOOTSTRAP_ON_START=true   # já ligado no railway.toml / Dockerfile
# ADMIN_BOOTSTRAP_EMAIL=admin@corte.com.br
# ADMIN_BOOTSTRAP_PASSWORD=corte@admin123
# ADMIN_BOOTSTRAP_FORCE=true      # resetar senha do admin no próximo deploy
