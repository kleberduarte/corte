    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "pdf-to-printer": "^5.8.0",
    "pdfkit": "^0.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.2",
    "@types/pdfkit": "^0.17.6",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.14.0",
    "tsx": "^4.15.4",
    "typescript": "^5.4.5"
